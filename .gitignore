# Unity asset serialization / cache
sysinfo.txt
*.stacktrace

# Burst / Addressables / Package cache
GalaxyXRTest_BurstDebugInformation_DoNotShip/
**/Assets/AssetStoreTools*
**/Packages/packages-lock.json.meta

# Build artifacts / installers / APKs
*.apk
*.aab
*.obb
*.keystore
*.jks
*.unitypackage

# Crash / backup folders often produced by Unity Android export
*_BackUpThisFolder_ButDontShipItWithYourGame/

# OS files
.DS_Store
Thumbs.db

# IDE / editor settings
.vscode/
.idea/
.vs/
.claude/
.utmp/

# Python cache (if scripts are added later)
__pycache__/
*.pyc
